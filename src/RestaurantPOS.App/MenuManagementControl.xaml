<UserControl x:Class="RestaurantPOS.App.MenuManagementControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F7F7F7">

    <UserControl.Resources>
        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Foreground" Value="#222222"/>
        </Style>

        <Style x:Key="EditorLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="EditorComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="EditorButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Left : Unified Editor -->
        <Border Grid.Column="0"
                Margin="0,0,10,0"
                Padding="12"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Editor"
                               Style="{StaticResource SectionTitleTextStyle}"/>

                    <TextBlock x:Name="TxtEditorModeTitle"
                               Margin="0,0,0,10"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#444444"
                               Text="No Selection"/>

                    <!-- Item Editor -->
                    <StackPanel x:Name="ItemEditorPanel"
                                Visibility="Collapsed">

                        <TextBlock Text="Item ID"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtItemId"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 IsReadOnly="True"
                                 Background="#F3F3F3"/>

                        <TextBlock Text="Item No"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtItemNo"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <TextBlock Text="Name"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtName"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <TextBlock Text="Name2"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtName2"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <TextBlock Text="Price"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtPrice"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <TextBlock Text="Sort Order"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtSortOrder"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <TextBlock Text="Station"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <ComboBox x:Name="CmbStation"
                                  Style="{StaticResource EditorComboBoxStyle}"/>

                        <TextBlock Text="Selected Category"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtCategory"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 IsReadOnly="True"
                                 Background="#F3F3F3"/>

                        <CheckBox x:Name="ChkIsActive"
                                  Margin="0,10,0,0"
                                  FontSize="14"
                                  Content="Active"/>

                        <Button x:Name="BtnAddNew"
                                Content="Add New Item"
                                Style="{StaticResource EditorButtonStyle}"/>

                        <Button x:Name="BtnSave"
                                Content="Save Item"
                                Style="{StaticResource EditorButtonStyle}"/>

                        <Button x:Name="BtnDelete"
                                Content="Delete Item"
                                Style="{StaticResource EditorButtonStyle}"/>
                    </StackPanel>

                    <!-- Category Editor -->
                    <StackPanel x:Name="CategoryEditorPanel"
                                Visibility="Collapsed">

                        <TextBlock Text="Category ID"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtCategoryId"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 IsReadOnly="True"
                                 Background="#F3F3F3"/>

                        <TextBlock Text="Category Name"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtCategoryName"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <TextBlock Text="Sort Order"
                                   Style="{StaticResource EditorLabelStyle}"/>
                        <TextBox x:Name="TxtCategorySortOrder"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                        <CheckBox x:Name="ChkCategoryIsActive"
                                  Margin="0,10,0,0"
                                  FontSize="14"
                                  Content="Active"/>

                        <Button x:Name="BtnAddNewCategory"
                                Content="Add New Category"
                                Style="{StaticResource EditorButtonStyle}"/>

                        <Button x:Name="BtnSaveCategory"
                                Content="Save Category"
                                Style="{StaticResource EditorButtonStyle}"/>

                        <Button x:Name="BtnDeleteCategory"
                                Content="Delete Category"
                                Style="{StaticResource EditorButtonStyle}"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtStatus"
                               Margin="0,14,0,0"
                               FontSize="12"
                               Foreground="#666666"
                               Text="Ready"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Center : Items Grid -->
        <Border Grid.Column="1"
                Margin="0,0,10,0"
                Padding="10"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <Grid DockPanel.Dock="Top"
                      Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Menu Items"
                               Style="{StaticResource SectionTitleTextStyle}"/>

                    <TextBlock x:Name="TxtItemsHeader"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="#666666"
                               Text="No Category Selected"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <UniformGrid x:Name="ItemsGrid"
                                 Rows="8"
                                 Columns="3"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Right : Categories Grid -->
        <Border Grid.Column="2"
                Padding="10"
                Background="White"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Categories"
                           Style="{StaticResource SectionTitleTextStyle}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <UniformGrid x:Name="CategoriesGrid"
                                 Rows="8"
                                 Columns="2"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>