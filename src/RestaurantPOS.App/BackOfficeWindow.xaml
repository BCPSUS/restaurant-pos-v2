<Window x:Class="RestaurantPOS.App.BackOfficeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Back Office"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="9*"/>
        </Grid.ColumnDefinitions>

        <!-- Left menu -->
        <Border Grid.Column="0"
                Background="#F3F3F3"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <TextBlock Text="Back Office"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,20"/>

                <Button x:Name="BtnMenu"
                        Content="Menu"
                        Height="40"
                        FontSize="13"
                        Margin="0,0,0,10"
                        Click="BtnMenu_Click"/>

                <Button x:Name="BtnPrinters"
                        Content="Printer"
                        Height="40"
                        FontSize="13"
                        Margin="0,0,0,10"/>

                <Button x:Name="BtnTables"
                        Content="Table"
                        Height="40"
                        FontSize="13"
                        Margin="0,0,0,10"/>

                <Button x:Name="BtnReturn"
                        Content="Return to POS"
                        Height="40"
                        FontSize="13"
                        Margin="0,30,0,0"
                        Click="BtnReturn_Click"/>
            </StackPanel>
        </Border>

        <!-- Right content -->
        <Border Grid.Column="1" Background="White">
            <ContentControl x:Name="MainContent"/>
        </Border>
    </Grid>
</Window>